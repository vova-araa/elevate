# ── Publiek (veilig om te committen; VITE_* wordt in de client gebundeld) ──
SUPABASE_PROJECT_ID="jouw-project-id"
SUPABASE_URL="https://jouw-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="jouw-anon-key"
VITE_SUPABASE_PROJECT_ID="jouw-project-id"
VITE_SUPABASE_URL="https://jouw-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="jouw-anon-key"

# ── Server-side secrets (NOOIT committen — zet deze op je host/deploy-omgeving) ──
# Supabase service-role key (admin-operaties op de server)
SUPABASE_SERVICE_ROLE_KEY=""

# Claude API voor alle AI-features (captions, planner, AI Studio, assistent)
ANTHROPIC_API_KEY=""
# Optioneel: ander Claude-model (default: claude-opus-4-8)
# CLAUDE_MODEL="claude-opus-4-8"

# Optioneel: publieke basis-URL (zonder deze variabele wordt het draaiende domein gebruikt).
# De OAuth redirect-URI is altijd ${APP_URL}/api/public/oauth/callback — zie docs/KOPPELINGEN.md
APP_URL="https://app.jouwdomein.nl"
# Optioneel: geheim voor het ondertekenen van de OAuth state-parameter
# OAUTH_STATE_SECRET=""

# Meta (Instagram/Facebook) developer-app
META_APP_ID=""
META_APP_SECRET=""

# TikTok developer-app
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# LinkedIn developer-app
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Google (YouTube — koppelen/statistieken; publiceren nog niet ondersteund)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Automation tick endpoint (cron beveiliging)
CRON_SECRET=""

# Publieke site-URL (voor links in webhooks/redirects)
# SITE_URL="https://app.jouwdomein.nl"
